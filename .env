# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
HOST=localhost

# ==========================================
# DATABASE CONFIGURATION (POSTGRESQL)
# ==========================================
PGUSER=postgres
PGHOST=localhost
PGPASSWORD=PostgreFayiz2662
PGDATABASE=openjob_db
PGPORT=5432

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Silakan ganti dengan string acak/secret key yang panjang dan aman
ACCESS_TOKEN_KEY=bikin_secret_key_access_token_bebas_tapi_panjang
REFRESH_TOKEN_KEY=bikin_secret_key_refresh_token_bebas_tapi_panjang
ACCESS_TOKEN_AGE=1h

# ==========================================
# CACHING (REDIS) - Kriteria 2
# ==========================================
# Sesuai instruksi Dicoding, nama variable harus persis seperti ini
REDIS_HOST=localhost

# ==========================================
# MESSAGE BROKER (RABBITMQ) - Kriteria 3
# ==========================================
# Sesuai instruksi Dicoding, nama variable harus persis seperti ini
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==========================================
# EMAIL NOTIFICATION (NODEMAILER) - Kriteria 3 Advanced
# ==========================================
# Sesuai instruksi Dicoding, nama variable harus persis seperti ini
# Gunakan kredensial SMTP dari layanan seperti Mailtrap.io atau Brevo
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=masukkan_user_mailtrap_kamu_di_sini
MAIL_PASSWORD=masukkan_password_mailtrap_kamu_di_sini